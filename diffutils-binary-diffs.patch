+   it under the terms of the GNU General Public License as published by
+   the Free Software Foundation, either version 3 of the License, or
+   (at your option) any later version.  */
+
+#ifndef DELTA_H
+# define DELTA_H
+
+# include <stddef.h>
+
+/* Opaque object for delta index.  */
+struct delta_index;
+
+/* Compute index data from BUF.  BUF must remain valid until
+   free_delta_index is called.  Return NULL on failure.  */
+struct delta_index *create_delta_index (void const *buf, unsigned long bufsize);
+
+void free_delta_index (struct delta_index *index);
+
+/* Create a delta from INDEX for BUF.  If MAX_DELTA_SIZE is nonzero and
+   the delta would be larger, return NULL.  On success store the size
+   in *DELTA_SIZE; caller must free the returned buffer.  */
+void *create_delta (struct delta_index const *index,
+                    void const *buf, unsigned long bufsize,
+                    unsigned long *delta_size, unsigned long max_delta_size);
+
+/* Create a delta from SRC_BUF to TRG_BUF.  */
+static inline void *
+diff_delta (void const *src_buf, unsigned long src_bufsize,
+            void const *trg_buf, unsigned long trg_bufsize,
+            unsigned long *delta_size, unsigned long max_delta_size)
+{
+  struct delta_index *index = create_delta_index (src_buf, src_bufsize);
+  if (index)
+    {
+      void *delta = create_delta (index, trg_buf, trg_bufsize,
+                                  delta_size, max_delta_size);
+      free_delta_index (index);
+      return delta;
+    }
+  return NULL;
+}
+
+#endif
