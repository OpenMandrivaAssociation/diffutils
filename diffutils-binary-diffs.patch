diff --git a/src/git-binary.c b/src/git-binary.c
new file mode 100644
index 0000000..f31b585
--- /dev/null
+++ b/src/git-binary.c
@@ -0,0 +1,346 @@
+/* git-binary.c -- emit diffs in the GIT binary patch format
+
+   Copyright (C) 2025-2026 Free Software Foundation, Inc.
+
+   This file is part of GNU DIFF.
+
+   This program is free software: you can redistribute it and/or modify
+   it under the terms of the GNU General Public License as published by
+   the Free Software Foundation, either version 3 of the License, or
+   (at your option) any later version.
+
+   The on-wire format matches Git's "GIT binary patch" output: a deflated
+   payload (literal file contents or a pack-style delta), encoded with
+   Git's base85 alphabet.  Compression uses zlib-ng.  */
+
+#include <config.h>
+
+#include "diff.h"
+#include "git-binary.h"
+#include "base85.h"
+#include "delta.h"
+#include "git-sha1.h"
+
+#include <inttypes.h>
+#include <limits.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <zlib-ng.h>
+
+#include <idx.h>
+#include <intprops.h>
+#include <stdckdint.h>
+#include <xalloc.h>
+
+/* When true, emit GIT binary patches for differing binary files.
+   Defaults to true; --no-binary-patch clears it.  */
+bool binary_patch = true;
+
+bool
+git_binary_patch_supported (void)
+{
+  switch (output_style)
+    {
+    case OUTPUT_UNSPECIFIED:
+    case OUTPUT_NORMAL:
+    case OUTPUT_CONTEXT:
+    case OUTPUT_UNIFIED:
+      return true;
+    default:
+      return false;
+    }
+}
+
+bool
+git_binary_patch_enabled (void)
+{
+  return binary_patch && !brief && git_binary_patch_supported ();
+}
+
+/* Return the git file mode bits for ST, or 0 if the file does not exist.  */
+static unsigned
+git_mode (struct file_data const *f)
+{
+  if (f->desc < 0)
+    return 0;
+  if (S_ISREG (f->stat.st_mode))
+    return (f->stat.st_mode & 0111) ? 0100755 : 0100644;
+  return 0100644;
+}
+
+static char const *
+file_bytes (struct file_data const *f)
+{
+  return f->buffer ? (char const *) f->buffer : "";
+}
+
+/* Feed up to UINT32_MAX bytes from *IN_LEFT starting at *IN_PTR.  */
+static void
+zng_set_input (zng_stream *stream, uint8_t const **in_ptr, size_t *in_left)
+{
+  uint32_t chunk = *in_left > UINT32_MAX ? UINT32_MAX : (uint32_t) *in_left;
+  stream->next_in = *in_ptr;
+  stream->avail_in = chunk;
+  *in_ptr += chunk;
+  *in_left -= chunk;
+}
+
+/* Deflate DATA[0..SIZE-1] with zlib-ng; store output length in
+   *RESULT_SIZE.  Caller frees the returned buffer.  */
+static unsigned char *
+deflate_it (void const *data, unsigned long size, unsigned long *result_size)
+{
+  zng_stream stream;
+  memset (&stream, 0, sizeof stream);
+
+  int32_t err = zng_deflateInit (&stream, Z_DEFAULT_COMPRESSION);
+  if (err != Z_OK)
+    fatal ("zlib-ng deflateInit failed");
+
+  size_t bound = zng_deflateBound (&stream, size);
+  if (!bound)
+    bound = 1;
+  idx_t out_alloc = bound;
+  unsigned char *deflated = ximalloc (out_alloc);
+  size_t out_pos = 0;
+
+  uint8_t const *in_ptr = data;
+  size_t in_left = size;
+  zng_set_input (&stream, &in_ptr, &in_left);
+
+  for (;;)
+    {
+      if (out_alloc - out_pos < 64 * 1024)
+        {
+          if (ckd_add (&out_alloc, out_alloc, out_alloc < 1024 * 1024
+                                               ? out_alloc
+                                               : 1024 * 1024))
+            xalloc_die ();
+          deflated = xirealloc (deflated, out_alloc);
+        }
+      uint32_t out_space = out_alloc - out_pos > UINT32_MAX
+                           ? UINT32_MAX
+                           : (uint32_t) (out_alloc - out_pos);
+      stream.next_out = deflated + out_pos;
+      stream.avail_out = out_space;
+
+      int flush = in_left || stream.avail_in ? Z_NO_FLUSH : Z_FINISH;
+      err = zng_deflate (&stream, flush);
+      out_pos = stream.total_out;
+
+      if (err == Z_STREAM_END)
+        break;
+      if (err != Z_OK && err != Z_BUF_ERROR)
+        {
+          zng_deflateEnd (&stream);
+          fatal ("zlib-ng deflate failed");
+        }
+      if (stream.avail_in == 0 && in_left)
+        zng_set_input (&stream, &in_ptr, &in_left);
+    }
+
+  zng_deflateEnd (&stream);
+  *result_size = out_pos;
+  return deflated;
+}
+
+/* Write one binary hunk (forward or reverse) for TWO derived from ONE.  */
+static void
+emit_binary_diff_body (char const *one_data, unsigned long one_size,
+                       char const *two_data, unsigned long two_size)
+{
+  unsigned long deflate_size;
+  unsigned char *deflated = deflate_it (two_data, two_size, &deflate_size);
+
+  void *delta = NULL;
+  unsigned long orig_size = 0;
+  unsigned long delta_size = 0;
+  if (one_size && two_size)
+    {
+      delta = diff_delta (one_data, one_size, two_data, two_size,
+                          &delta_size, deflate_size);
+      if (delta)
+        {
+          void *raw = delta;
+          orig_size = delta_size;
+          delta = deflate_it (raw, delta_size, &delta_size);
+          free (raw);
+        }
+    }
+
+  unsigned char *data;
+  unsigned long data_size;
+  if (delta && delta_size < deflate_size)
+    {
+      fprintf (outfile, "delta %lu\n", orig_size);
+      free (deflated);
+      data = delta;
+      data_size = delta_size;
+    }
+  else
+    {
+      fprintf (outfile, "literal %lu\n", two_size);
+      free (delta);
+      data = deflated;
+      data_size = deflate_size;
+    }
+
+  unsigned char *cp = data;
+  while (data_size)
+    {
+      int bytes = data_size > 52 ? 52 : data_size;
+      char line[1 + ((52 + 3) / 4) * 5 + 1];
+      data_size -= bytes;
+      line[0] = bytes <= 26 ? bytes + 'A' - 1 : bytes - 26 + 'a' - 1;
+      encode_85 (line + 1, cp, bytes);
+      cp += bytes;
+      fputs (line, outfile);
+      putc ('\n', outfile);
+    }
+  putc ('\n', outfile);
+  free (data);
+}
+
+/* Quote NAME for a "diff --git" header path.  Uses C-style quoting when
+   NAME contains spaces or special characters, matching historical git
+   output for common cases; otherwise returns NAME unchanged (owned by
+   caller).  The return value must be freed if it != NAME.  */
+static char const *
+git_path_quote (char const *name, char **storage)
+{
+  bool need_quote = false;
+  for (char const *p = name; *p; p++)
+    {
+      unsigned char c = *p;
+      if (c <= 0x20 || c == '"' || c == '\\' || c == 0x7f)
+        {
+          need_quote = true;
+          break;
+        }
+    }
+  if (!need_quote)
+    {
+      *storage = NULL;
+      return name;
+    }
+
+  idx_t len = strlen (name);
+  /* Worst case: every byte becomes \nnn plus quotes.  */
+  char *buf = ximalloc (len * 4 + 3);
+  char *q = buf;
+  *q++ = '"';
+  for (char const *p = name; *p; p++)
+    {
+      unsigned char c = *p;
+      if (c == '"' || c == '\\')
+        {
+          *q++ = '\\';
+          *q++ = c;
+        }
+      else if (c == '\n')
+        {
+          *q++ = '\\';
+          *q++ = 'n';
+        }
+      else if (c == '\t')
+        {
+          *q++ = '\\';
+          *q++ = 't';
+        }
+      else if (c < 0x20 || c == 0x7f)
+        {
+          sprintf (q, "\\%03o", c);
+          q += 4;
+        }
+      else
+        *q++ = c;
+    }
+  *q++ = '"';
+  *q = 0;
+  *storage = buf;
+  return buf;
+}
+
+void
+print_git_binary_patch (struct file_data filevec[],
+                        char const *name0, char const *name1,
+                        bool recursive)
+{
+  setup_output (name0, name1, recursive);
+
+  /* Avoid the ---/+++ headers that begin_output prints for -u/-c; the
+     GIT binary patch header block stands alone.  Still honor --paginate.  */
+  enum output_style saved_style = output_style;
+  output_style = OUTPUT_NORMAL;
+  bool saved_recursive = recursive;
+  /* begin_output prints a "diff ..." banner when recursive; the
+     diff --git line below supersedes it, so suppress the banner.  */
+  setup_output (name0, name1, false);
+  begin_output ();
+  output_style = saved_style;
+  (void) saved_recursive;
+
+  char const *raw0 = file_label[0] ? file_label[0] : name0;
+  char const *raw1 = file_label[1] ? file_label[1] : name1;
+  /* For pure creation/deletion git repeats the existing name on both
+     sides of the diff --git line.  */
+  bool old_missing = filevec[0].desc < 0;
+  bool new_missing = filevec[1].desc < 0;
+  if (old_missing && !new_missing)
+    raw0 = raw1;
+  else if (new_missing && !old_missing)
+    raw1 = raw0;
+
+  char *stor0 = NULL;
+  char *stor1 = NULL;
+  char const *q0 = git_path_quote (raw0, &stor0);
+  char const *q1 = git_path_quote (raw1, &stor1);
+
+  fprintf (outfile, "diff --git a/%s b/%s\n", q0, q1);
+
+  unsigned mode0 = git_mode (&filevec[0]);
+  unsigned mode1 = git_mode (&filevec[1]);
+
+  if (old_missing && !new_missing)
+    fprintf (outfile, "new file mode %06o\n", mode1);
+  else if (new_missing && !old_missing)
+    fprintf (outfile, "deleted file mode %06o\n", mode0);
+  else if (mode0 && mode1 && mode0 != mode1)
+    {
+      fprintf (outfile, "old mode %06o\n", mode0);
+      fprintf (outfile, "new mode %06o\n", mode1);
+    }
+
+  char oid0[GIT_SHA1_HEX_SIZE + 1];
+  char oid1[GIT_SHA1_HEX_SIZE + 1];
+  unsigned long size0 = old_missing ? 0 : (unsigned long) filevec[0].buffered;
+  unsigned long size1 = new_missing ? 0 : (unsigned long) filevec[1].buffered;
+  char const *data0 = old_missing ? "" : file_bytes (&filevec[0]);
+  char const *data1 = new_missing ? "" : file_bytes (&filevec[1]);
+
+  if (old_missing)
+    strcpy (oid0, "0000000000000000000000000000000000000000");
+  else
+    git_blob_oid_hex (oid0, data0, size0);
+  if (new_missing)
+    strcpy (oid1, "0000000000000000000000000000000000000000");
+  else
+    git_blob_oid_hex (oid1, data1, size1);
+
+  if (old_missing || new_missing || mode0 != mode1)
+    fprintf (outfile, "index %s..%s\n", oid0, oid1);
+  else
+    fprintf (outfile, "index %s..%s %06o\n", oid0, oid1, mode1);
+
+  fputs ("GIT binary patch\n", outfile);
+  emit_binary_diff_body (data0, size0, data1, size1);
+  emit_binary_diff_body (data1, size1, data0, size0);
+
+  finish_output ();
+
+  free (stor0);
+  free (stor1);
+}
