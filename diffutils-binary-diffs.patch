diff --git a/src/git-sha1.c b/src/git-sha1.c
new file mode 100644
index 0000000..62439f4
--- /dev/null
+++ b/src/git-sha1.c
@@ -0,0 +1,159 @@
+/* git-sha1.c -- SHA-1 and git blob object IDs
+
+   Copyright (C) 2025-2026 Free Software Foundation, Inc.
+
+   This file is part of GNU DIFF.
+
+   This program is free software: you can redistribute it and/or modify
+   it under the terms of the GNU General Public License as published by
+   the Free Software Foundation, either version 3 of the License, or
+   (at your option) any later version.  */
+
+#include <config.h>
+
+#include "git-sha1.h"
+
+#include <string.h>
+#include <stdio.h>
+
+/* Compact SHA-1 implementation.  */
+
+struct sha1_ctx
+{
+  uint32_t state[5];
+  uint64_t count;
+  unsigned char buffer[64];
+};
+
+static uint32_t
+rol (uint32_t x, int n)
+{
+  return (x << n) | (x >> (32 - n));
+}
+
+static void
+sha1_transform (uint32_t state[5], unsigned char const buffer[64])
+{
+  uint32_t a, b, c, d, e, t, w[80];
+
+  for (int i = 0; i < 16; i++)
+    w[i] = ((uint32_t) buffer[i * 4] << 24)
+           | ((uint32_t) buffer[i * 4 + 1] << 16)
+           | ((uint32_t) buffer[i * 4 + 2] << 8)
+           | buffer[i * 4 + 3];
+  for (int i = 16; i < 80; i++)
+    w[i] = rol (w[i - 3] ^ w[i - 8] ^ w[i - 14] ^ w[i - 16], 1);
+
+  a = state[0];
+  b = state[1];
+  c = state[2];
+  d = state[3];
+  e = state[4];
+
+  for (int i = 0; i < 80; i++)
+    {
+      if (i < 20)
+        t = rol (a, 5) + ((b & c) | (~b & d)) + e + w[i] + 0x5A827999;
+      else if (i < 40)
+        t = rol (a, 5) + (b ^ c ^ d) + e + w[i] + 0x6ED9EBA1;
+      else if (i < 60)
+        t = rol (a, 5) + ((b & c) | (b & d) | (c & d)) + e + w[i] + 0x8F1BBCDC;
+      else
+        t = rol (a, 5) + (b ^ c ^ d) + e + w[i] + 0xCA62C1D6;
+      e = d;
+      d = c;
+      c = rol (b, 30);
+      b = a;
+      a = t;
+    }
+
+  state[0] += a;
+  state[1] += b;
+  state[2] += c;
+  state[3] += d;
+  state[4] += e;
+}
+
+static void
+sha1_init (struct sha1_ctx *ctx)
+{
+  ctx->state[0] = 0x67452301;
+  ctx->state[1] = 0xEFCDAB89;
+  ctx->state[2] = 0x98BADCFE;
+  ctx->state[3] = 0x10325476;
+  ctx->state[4] = 0xC3D2E1F0;
+  ctx->count = 0;
+}
+
+static void
+sha1_update (struct sha1_ctx *ctx, void const *data, size_t len)
+{
+  unsigned char const *p = data;
+  size_t i = ctx->count & 63;
+  ctx->count += len;
+  while (len--)
+    {
+      ctx->buffer[i++] = *p++;
+      if (i == 64)
+        {
+          sha1_transform (ctx->state, ctx->buffer);
+          i = 0;
+        }
+    }
+}
+
+static void
+sha1_final (unsigned char digest[GIT_SHA1_DIGEST_SIZE], struct sha1_ctx *ctx)
+{
+  unsigned char finalcount[8];
+  uint64_t bits = ctx->count * 8;
+  for (int i = 0; i < 8; i++)
+    finalcount[i] = bits >> (56 - 8 * i);
+
+  unsigned char c = 0x80;
+  sha1_update (ctx, &c, 1);
+  c = 0;
+  while ((ctx->count & 63) != 56)
+    sha1_update (ctx, &c, 1);
+  sha1_update (ctx, finalcount, 8);
+
+  for (int i = 0; i < 5; i++)
+    {
+      digest[i * 4] = ctx->state[i] >> 24;
+      digest[i * 4 + 1] = ctx->state[i] >> 16;
+      digest[i * 4 + 2] = ctx->state[i] >> 8;
+      digest[i * 4 + 3] = ctx->state[i];
+    }
+}
+
+void
+git_sha1_to_hex (char hex[GIT_SHA1_HEX_SIZE + 1],
+                 unsigned char const digest[GIT_SHA1_DIGEST_SIZE])
+{
+  static char const xdigits[] = "0123456789abcdef";
+  for (int i = 0; i < GIT_SHA1_DIGEST_SIZE; i++)
+    {
+      hex[i * 2] = xdigits[digest[i] >> 4];
+      hex[i * 2 + 1] = xdigits[digest[i] & 15];
+    }
+  hex[GIT_SHA1_HEX_SIZE] = 0;
+}
+
+void
+git_blob_oid_hex (char hex[GIT_SHA1_HEX_SIZE + 1],
+                  void const *data, size_t size)
+{
+  struct sha1_ctx ctx;
+  char header[32];
+  int header_len = sprintf (header, "blob %zu", size);
+  header[header_len++] = 0;
+
+  sha1_init (&ctx);
+  sha1_update (&ctx, header, header_len);
+  if (size)
+    sha1_update (&ctx, data, size);
+
+  unsigned char digest[GIT_SHA1_DIGEST_SIZE];
+  sha1_final (digest, &ctx);
+  git_sha1_to_hex (hex, digest);
+}
