new file mode 100755
index 0000000..d95426a
--- /dev/null
+++ b/tests/git-binary
@@ -0,0 +1,62 @@
+#!/bin/sh
+# GIT binary patch output
+
+. "${srcdir=.}/init.sh"; path_prepend_ ../src
+
+fail=0
+
+mkdir old new || framework_failure_
+printf 'hello\0world\0' > old/f.bin || framework_failure_
+printf 'hello\0WORLD\0extra' > new/f.bin || framework_failure_
+printf '\0\1\2\3' > new/c.bin || framework_failure_
+
+# Basic modification patch contains the GIT binary patch marker and index.
+returns_ 1 diff --label f.bin --label f.bin old/f.bin new/f.bin > out 2> err || fail=1
+compare /dev/null err || fail=1
+grep -F 'diff --git a/f.bin b/f.bin' out || fail=1
+grep -F 'GIT binary patch' out || fail=1
+grep -E '^(literal|delta) ' out || fail=1
+grep -E '^index [0-9a-f]{40}\.\.[0-9a-f]{40} ' out || fail=1
+
+# OIDs must match git's blob SHA-1.
+oid_a=$(git hash-object old/f.bin) || framework_failure_
+oid_b=$(git hash-object new/f.bin) || framework_failure_
+grep -F "index ${oid_a}..${oid_b}" out || fail=1
+
+# Interoperability: git apply accepts our patch in a clean tree.
+returns_ 1 diff --label f.bin --label f.bin old/f.bin new/f.bin > ab.patch || fail=1
+workdir=$(mktemp -d) || framework_failure_
+cp old/f.bin "$workdir/f.bin" || framework_failure_
+cp ab.patch "$workdir/ab.patch" || framework_failure_
+(
+  cd "$workdir" || exit 1
+  git init -q || exit 1
+  git apply --check ab.patch || exit 1
+  git apply ab.patch || exit 1
+) || fail=1
+compare new/f.bin "$workdir/f.bin" || fail=1
+rm -rf "$workdir"
+
+# New file and deletion.
+returns_ 1 diff -N missing.bin new/c.bin > new.patch 2> err || fail=1
+compare /dev/null err || fail=1
+grep -F 'new file mode' new.patch || fail=1
+grep -F 'GIT binary patch' new.patch || fail=1
+grep -F 'literal 4' new.patch || fail=1
+grep -F 'literal 0' new.patch || fail=1
+
+returns_ 1 diff -N new/c.bin missing2.bin > del.patch 2> err || fail=1
+compare /dev/null err || fail=1
+grep -F 'deleted file mode' del.patch || fail=1
+
+# --no-binary-patch restores classic output; -y does not emit patches.
+printf 'Binary files old/f.bin and new/f.bin differ\n' > classic-exp || framework_failure_
+returns_ 1 diff --no-binary-patch old/f.bin new/f.bin > classic 2> err || fail=1
+compare /dev/null err || fail=1
+compare classic-exp classic || fail=1
+
+returns_ 1 diff -y old/f.bin new/f.bin > side 2> err || fail=1
+grep -F 'Binary files' side || fail=1
+grep -F 'GIT binary patch' side && fail=1
+
+Exit $fail
