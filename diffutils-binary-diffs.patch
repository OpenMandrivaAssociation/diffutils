+/* git-sha1.h -- SHA-1 for git blob object IDs in binary patches
+
+   Copyright (C) 2025-2026 Free Software Foundation, Inc.
+
+   This file is part of GNU DIFF.  */
+
+#ifndef GIT_SHA1_H
+# define GIT_SHA1_H
+
+# include <stddef.h>
